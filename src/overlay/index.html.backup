<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TWiSTroll</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

  :root {
    --twist-red: #FF4D00;
    --dark: #1E1E22;
    --card-bg: rgba(255,255,255,0.04);
    --card-border: rgba(255,255,255,0.06);
    --text: #F1F1F1;
    --text-muted: #64748B;
    --jamie: #2DD4BF;
    --delinquent: #F97316;
    --honest: #A78BFA;
    --taco: #84CC16;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: rgba(0,0,0,0) !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--text);
    width: 340px;
    height: 1080px;
  }

  .sidebar {
    width: 340px;
    height: 1080px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sidebar.sidebar-mode {
    background: rgba(30, 30, 34, 0.92);
  }

  /* ─── Header ─── */
  .header {
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 2px solid var(--twist-red);
    background: rgba(0,0,0,0.25);
    flex-shrink: 0;
  }

  .header-title {
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--twist-red);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .live-badge {
    font-size: 8px;
    font-weight: 700;
    color: var(--twist-red);
    border: 1px solid rgba(255, 77, 0, 0.25);
    padding: 1px 5px;
    border-radius: 3px;
    letter-spacing: 0.06em;
  }

  .header-right {
    margin-left: auto;
    font-size: 8px;
    color: var(--text-muted);
  }

  .header.reconnecting .live-dot {
    background: #ef4444;
    animation: pulse 0.8s ease-in-out infinite;
  }

  .header.reconnecting .header-title {
    color: #ef4444;
  }

  /* ─── Personas Container ─── */
  .personas {
    flex: 1;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
  }

  /* ─── Persona Panel ─── */
  .persona {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--card-bg);
    border-radius: 8px;
    padding: 16px 18px;
    border-left: 5px solid transparent;
    opacity: 0.5;
    transition: opacity 300ms ease;
    will-change: transform, opacity;
  }

  .persona.active {
    opacity: 1;
  }

  .persona.pop {
    animation: pop-in 300ms ease-out;
  }

  @keyframes pop-in {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.03); }
    100% { transform: scale(1); }
  }

  /* Persona colors via border-left */
  .persona[data-id="not-jamie"]      { border-left-color: var(--jamie); }
  .persona[data-id="not-delinquent"] { border-left-color: var(--delinquent); }
  .persona[data-id="not-honest"]     { border-left-color: var(--honest); }
  .persona[data-id="not-taco"]       { border-left-color: var(--taco); }

  /* ─── Avatar ─── */
  .avatar {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Info ─── */
  .info {
    flex: 1;
    min-width: 0;
  }

  .name {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin-bottom: 4px;
    display: block;
  }

  .persona[data-id="not-jamie"]      .name { color: var(--jamie); }
  .persona[data-id="not-delinquent"] .name { color: var(--delinquent); }
  .persona[data-id="not-honest"]     .name { color: var(--honest); }
  .persona[data-id="not-taco"]       .name { color: var(--taco); }

  .reaction {
    font-size: 14px;
    line-height: 1.45;
    color: var(--text);
    transition: opacity 200ms ease;
    min-height: 40px;
  }

  .reaction.fading {
    opacity: 0;
  }

  .role {
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin-top: 1px;
  }

  /* ─── Status Bar ─── */
  .status-bar {
    padding: 8px 16px;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .status-bar span {
    font-size: 9px;
    color: var(--text-muted);
  }

  .status-bar .accent {
    color: var(--twist-red);
    font-weight: 700;
  }

  .status-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--taco);
    flex-shrink: 0;
  }

  /* Prod mode hides status bar */
  .sidebar.prod .status-bar { display: none; }
</style>
</head>
<body>

<div class="sidebar sidebar-mode" id="sidebar">

  <div class="header" id="header">
    <div class="live-dot" id="live-dot"></div>
    <div class="header-title" id="header-title">TWiSTroll</div>
    <div class="live-badge">LIVE</div>
    <div class="header-right">Powered by OpenOats</div>
  </div>

  <div class="personas">

    <div class="persona active" data-id="not-jamie" id="panel-not-jamie">
      <div class="avatar">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#2DD4BF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
      <div class="info">
        <span class="name">Not Jamie</span>
        <div class="role">Fact-checker</div>
        <div class="reaction" id="text-not-jamie">Waiting for transcript...</div>
      </div>
    </div>

    <div class="persona" data-id="not-delinquent" id="panel-not-delinquent">
      <div class="avatar">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L8.5 8L4 10L7 15L6 20L12 17L18 20L17 15L20 10L15.5 8Z"/></svg>
      </div>
      <div class="info">
        <span class="name">Not Delinquent</span>
        <div class="role">Chaotic troll</div>
        <div class="reaction" id="text-not-delinquent">Waiting for transcript...</div>
      </div>
    </div>

    <div class="persona" data-id="not-honest" id="panel-not-honest">
      <div class="avatar">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="8.5" cy="9.5" r="1.2"/><circle cx="15.5" cy="9.5" r="1.2"/><path d="M8 15L10 16L14 16L16 15"/></svg>
      </div>
      <div class="info">
        <span class="name">Not Honest</span>
        <div class="role">Cynical troll</div>
        <div class="reaction" id="text-not-honest">Waiting for transcript...</div>
      </div>
    </div>

    <div class="persona" data-id="not-taco" id="panel-not-taco">
      <div class="avatar">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#84CC16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="14" rx="7" ry="5"/><path d="M6 10L5 6L8 9"/><path d="M18 10L19 6L16 9"/><path d="M9 18L12 20L15 18"/></svg>
      </div>
      <div class="info">
        <span class="name">Not Taco</span>
        <div class="role">Comedy troll</div>
        <div class="reaction" id="text-not-taco">Waiting for transcript...</div>
      </div>
    </div>

  </div>

  <div class="status-bar" id="status-bar">
    <div class="status-dot" id="status-dot"></div>
    <span class="accent">TWiSTroll</span>
    <span>&bull;</span>
    <span id="session-label">Connecting...</span>
    <span>&bull;</span>
    <span>Last: <strong id="last-reaction-time">—</strong></span>
  </div>

</div>

<script>
(function() {
  // ─── URL Params ───
  var params = new URLSearchParams(window.location.search);
  var mode = params.get('mode') || 'sidebar';

  var sidebar = document.getElementById('sidebar');
  if (mode === 'prod') {
    sidebar.classList.add('prod');
    sidebar.classList.add('sidebar-mode');
  } else if (mode === 'overlay') {
    sidebar.classList.remove('sidebar-mode');
  } else {
    sidebar.classList.add('sidebar-mode');
  }

  // ─── State ───
  var lastReactionTime = null;
  var ws = null;
  var reconnectTimer = null;
  var reconnectDelay = 1000;

  // ─── WebSocket ───
  function connect() {
    var wsUrl = 'ws://localhost:3001';
    ws = new WebSocket(wsUrl);

    ws.onopen = function() {
      console.log('[TWiSTroll] WebSocket connected');
      reconnectDelay = 1000;
      setHeaderState('connected');
    };

    ws.onmessage = function(event) {
      try {
        var msg = JSON.parse(event.data);
        handleMessage(msg);
      } catch(e) {
        console.error('[TWiSTroll] Parse error:', e);
      }
    };

    ws.onclose = function() {
      console.log('[TWiSTroll] WebSocket closed, reconnecting in', reconnectDelay, 'ms');
      setHeaderState('reconnecting');
      scheduleReconnect();
    };

    ws.onerror = function() {
      // onclose will fire after this
    };
  }

  function scheduleReconnect() {
    if (reconnectTimer) clearTimeout(reconnectTimer);
    reconnectTimer = setTimeout(function() {
      reconnectDelay = Math.min(reconnectDelay * 1.5, 10000);
      connect();
    }, reconnectDelay);
  }

  function setHeaderState(state) {
    var header = document.getElementById('header');
    var title = document.getElementById('header-title');
    var sessionLabel = document.getElementById('session-label');

    header.classList.remove('reconnecting');

    if (state === 'reconnecting') {
      header.classList.add('reconnecting');
      title.textContent = 'Reconnecting...';
    } else {
      title.textContent = 'TWiSTroll';
    }
  }

  // ─── Message Handler ───
  function handleMessage(msg) {
    if (msg.type === 'troll_comment') {
      updatePersona(msg.persona, msg.text);
      lastReactionTime = Date.now();
    } else if (msg.type === 'status') {
      var sessionLabel = document.getElementById('session-label');
      if (msg.session) {
        sessionLabel.textContent = 'Live on ' + msg.session;
      }
      if (msg.state === 'ollama_down') {
        sessionLabel.textContent = 'Ollama offline';
        document.getElementById('status-dot').style.background = '#ef4444';
      } else if (msg.state === 'connected' || msg.state === 'idle') {
        document.getElementById('status-dot').style.background = '#84CC16';
      } else if (msg.state === 'processing') {
        document.getElementById('status-dot').style.background = '#FF4D00';
      }
    }
  }

  // ─── Update Persona Bubble ───
  function updatePersona(id, text) {
    var panel = document.getElementById('panel-' + id);
    var textEl = document.getElementById('text-' + id);
    if (!panel || !textEl) return;

    // 1. Fade out old text
    textEl.classList.add('fading');

    setTimeout(function() {
      // 2. Swap text + fade in
      textEl.textContent = text;
      textEl.classList.remove('fading');

      // 3. Set active state (dim others)
      var allPanels = document.querySelectorAll('.persona');
      for (var i = 0; i < allPanels.length; i++) {
        allPanels[i].classList.remove('active');
      }
      panel.classList.add('active');

      // 4. Pop animation
      panel.classList.remove('pop');
      void panel.offsetWidth; // force reflow
      panel.classList.add('pop');

      setTimeout(function() {
        panel.classList.remove('pop');
      }, 310);
    }, 200);
  }

  // ─── Last Reaction Timer ───
  setInterval(function() {
    var el = document.getElementById('last-reaction-time');
    if (lastReactionTime) {
      var seconds = Math.floor((Date.now() - lastReactionTime) / 1000);
      el.textContent = seconds + 's ago';
    }
  }, 1000);

  // ─── Boot ───
  connect();
})();
</script>
</body>
</html>
