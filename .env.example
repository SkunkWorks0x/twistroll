OPENOATS_TRANSCRIPT_DIR=~/Library/Application Support/OpenOats/sessions
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FACTCHECKER=qwen2.5:7b
OLLAMA_MODEL_TROLLS=qwen2.5:7b
WS_PORT=3001
OVERLAY_PORT=3000
COOLDOWN_MS=18000    # 18s ceiling set 2026-04-15 after Phase 1 tuning
CONTEXT_BUFFER_SIZE=4
LLM_MODE=hybrid
CLOUD_API_KEY=           # Anthropic API key (legacy — used by cloud-llm.ts)
ANTHROPIC_API_KEY=       # Anthropic API key (used by llm-router.ts haiku provider)
CLOUD_MODEL=claude-haiku-4-5-20251001
GROK_API_KEY=            # xAI (Grok) API key — used by llm-router.ts for Taco
GROQ_API_KEY=            # Groq API key (free tier)
GROQ_MODEL=llama-3.3-70b-versatile
# Fred sound-effect trigger threshold (1-10)
# Production default: 9 (conservative, fewer false-positives)
# Demo override: 5 (more sensitive — used during validation)
FRED_TRIGGER_THRESHOLD=5
